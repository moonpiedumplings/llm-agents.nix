+test("add path follows symlinks to GGUF targets", async () => {
+  const dir = await mkdtemp(path.join(tmpdir(), "umr-symlink-"));
+  const sourceDir = path.join(dir, "source");
+  await mkdir(sourceDir, { recursive: true });
+  const targetPath = path.join(sourceDir, "tiny.gguf");
+  const symlinkPath = path.join(sourceDir, "tiny-link");
+  await createTestGGUF(targetPath);
+  await symlink(targetPath, symlinkPath);
+
+  const umr = createVMR(path.join(dir, "home"));
+  const added = await umr.addSource("path", { path: symlinkPath });
+
+  expect(added.model.name).toBe("tiny");
+  expect(added.model.entryFilename).toBe("tiny.gguf");
+  const pathSource = added.model.sources.find((source) => source.kind === "path");
+  expect(pathSource).toBeTruthy();
+  expect(pathSource?.payload.originalPath).toBe(path.resolve(symlinkPath));
+  expect(pathSource?.payload.resolvedPath).toBe(path.resolve(targetPath));
+});
+
